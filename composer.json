{
    "name": "digitalshopfront/security",
    "description": "Provides escaping and sanitation functions to provide security for Digital Shopfront CMS.",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "version": "1.0.1",
    "autoload": {
        "psr-4": {
            "Digitalshopfront\\Security\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Jacob Martella",
            "email": "me@jacobmartella.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": ">=5.3",
        "laminas/laminas-escaper": "^2.16"
    },
    "require-dev": {
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-laravel": "^3.1"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Digitalshopfront\\Security\\SecurityServiceProvider"
            ],
            "aliases": {
                "Security": "Digitalshopfront\\Security\\Facades\\Security"
            }
        }
    }
}
